// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Roles de usuario
enum Role {
  LEADER
  AGENT
  ADMIN
}

// Estado de solicitudes
enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Tipo de solicitud
enum RequestType {
  SCHEDULE_SWAP // Cambio de horario con otro agente
  DAY_OFF_SWAP  // Cambio de franco con otro agente
  SCHEDULE_CHANGE // Cambio individual de horario
}

// Día de la semana
enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// Usuario del sistema
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(AGENT)

  // Campos adicionales para gestión de francos
  firstName     String?
  lastName      String?

  // Email configurado manualmente por admin (para excepciones)
  emailManuallySet Boolean @default(false)

  // DNI del agente (para cruzar con nómina)
  dni           String?

  // Employee ID / Legajo (para métricas operativas)
  employeeId    String?   @unique

  // Skill / Campaña del agente
  skill         String?

  // Estado laboral del agente
  employmentStatus String? @default("ACTIVE") // ACTIVE | INACTIVE | SUSPENDED | RESIGNED

  // Relaciones
  teamId        String?
  team          Team?     @relation("TeamMembers", fields: [teamId], references: [id])

  // Isla del agente (para métricas operativas)
  islandId      String?
  island        Island?   @relation("IslandAgents", fields: [islandId], references: [id])

  // Líder que supervisa a este usuario (solo para agentes)
  leaderId      String?
  leader        User?     @relation("LeaderSupervisor", fields: [leaderId], references: [id])
  supervisees   User[]    @relation("LeaderSupervisor")

  // Configuración del agente
  weeklyDayOff  WeekDay?

  // Relaciones con otros modelos
  schedules     Schedule[] @relation("UserSchedules")
  breaks        Break[]    @relation("UserBreaks")
  requests      Request[] @relation("Requester")
  requestsAsAgent Request[] @relation("InvolvedAgent")
  resolvedRequests Request[] @relation("ResolvedBy")
  notifications  Notification[]
  auditLogs     AuditLog[]
  ledTeams     Team[] @relation("TeamLeader")

  // Relaciones con métricas operativas
  operationsMetrics OperationsMetric[]
  uploadedOperations OperationsUpload[] @relation("UploadCreator")

  // Objetivos individuales (como agente)
  agentGoals    AgentGoal[] @relation("AgentGoalTarget")

  // Objetivos asignados (como líder)
  assignedGoals AgentGoal[] @relation("LeaderAssignedGoals")

  // Relaciones con NextAuth
  accounts      Account[]
  sessions      Session[]

  // Fechas
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  @@index([email])
  @@index([role])
  @@index([teamId])
  @@index([leaderId])
  @@index([dni])
  @@index([employeeId])
  @@index([islandId])
}

// Modelos para NextAuth
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Equipos de trabajo
model Team {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?

  // Líder del equipo
  leaderId    String    @unique
  leader      User      @relation("TeamLeader", fields: [leaderId], references: [id])

  // Miembros del equipo
  members     User[]    @relation("TeamMembers")

  // Horarios y breaks del equipo
  schedules   Schedule[] @relation("TeamSchedules")
  breaks      Break[]    @relation("TeamBreaks")

  // Fechas
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([leaderId])
}

// Horarios de trabajo
model Schedule {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserSchedules", fields: [userId], references: [id])

  teamId      String?
  team        Team?     @relation("TeamSchedules", fields: [teamId], references: [id])

  // Horario: formato HH:MM-HH:MM (ej: "09:00-18:00")
  timeRange   String

  // Vigencia del horario
  validFrom   DateTime
  validTo     DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([teamId])
  @@index([validFrom, validTo])
}

// Horarios de break
model Break {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserBreaks", fields: [userId], references: [id])

  teamId      String?
  team        Team?     @relation("TeamBreaks", fields: [teamId], references: [id])

  // Tipo: DAILY (mismo horario todos los días) o WEEKLY (diferente cada día)
  type        String    @default("DAILY") // DAILY | WEEKLY

  // Para DAILY: horario del break
  timeRange   String?   // formato HH:MM-HH:MM

  // Para WEEKLY: día y horario específico
  dayOfWeek   WeekDay?
  weeklyTime  String?   // formato HH:MM-HH:MM

  // Duración en minutos
  duration    Int?      @default(15)

  // Vigencia
  validFrom   DateTime
  validTo     DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([teamId])
  @@index([validFrom, validTo])
}

// Solicitudes de cambio
model Request {
  id            String        @id @default(cuid())

  // Solicitante
  requesterId   String
  requester     User          @relation("Requester", fields: [requesterId], references: [id])

  // Tipo de solicitud
  type          RequestType

  // Agente involucrado (para swaps)
  involvedAgentId String?
  involvedAgent  User?        @relation("InvolvedAgent", fields: [involvedAgentId], references: [id])

  // Fechas y horarios
  requestDate   DateTime      @default(now())
  targetDate    DateTime      // Fecha del cambio solicitado

  // Horario actual y solicitado
  currentSchedule String?
  requestedSchedule String?

  // Motivo del cambio
  reason        String?

  // Estado
  status        RequestStatus  @default(PENDING)

  // Resolución
  resolvedBy    String?       // ID del líder que resolvió
  resolvedByUser User?        @relation("ResolvedBy", fields: [resolvedBy], references: [id])
  resolvedAt    DateTime?
  comment       String?       // Comentario del líder

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([requesterId])
  @@index([status])
  @@index([requestDate])
  @@index([targetDate])
}

// Notificaciones
model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  type        String    // REQUEST_PENDING | REQUEST_APPROVED | REQUEST_REJECTED
  title       String
  message     String

  // Relación con solicitud (si aplica)
  requestId   String?

  read        Boolean   @default(false)

  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// Logs de auditoría
model AuditLog {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])

  action      String    // LOGIN | SCHEDULE_CREATE | SCHEDULE_UPDATE | REQUEST_CREATE | REQUEST_APPROVE | REQUEST_REJECT
  entity      String    // USER | SCHEDULE | BREAK | REQUEST
  entityId    String?
  changes     Json?     // Cambios realizados

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ============================================
// MÓDULO DE MÉTRICAS OPERATIVAS
// ============================================

// Isla / Segmento operativo
model Island {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String?   @unique
  description String?

  isActive    Boolean   @default(true)

  // Agentes asignados a esta isla
  agents      User[]    @relation("IslandAgents")

  // Umbrales configurados para esta isla
  threshold   IslandThreshold?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

// Umbrales operativos por isla
model IslandThreshold {
  id          String   @id @default(cuid())

  islandId    String   @unique
  island      Island   @relation(fields: [islandId], references: [id], onDelete: Cascade)

  // TMO (Tiempo Medio de Operación) en segundos
  targetTmo   Int      @default(360)      // 6 minutos
  warningTmo  Int      @default(420)     // 7 minutos
  criticalTmo Int      @default(480)     // 8 minutos

  // Break en segundos
  targetBreak   Int    @default(900)     // 15 minutos
  warningBreak  Int    @default(1080)    // 18 minutos
  criticalBreak Int    @default(1260)    // 21 minutos

  // ACW (After Call Work) en segundos
  targetAcw   Int      @default(30)      // 30 segundos
  warningAcw  Int      @default(45)      // 45 segundos
  criticalAcw Int      @default(60)      // 60 segundos

  // Hold (Tiempo en espera) en segundos
  targetHold  Int      @default(60)      // 60 segundos
  warningHold Int      @default(90)      // 90 segundos
  criticalHold Int     @default(120)     // 120 segundos

  // Adherencia (porcentaje)
  targetAdherence Float @default(95.0)   // 95%
  warningAdherence Float @default(90.0)  // 90%
  criticalAdherence Float @default(85.0) // 85%

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([islandId])
}

// Registro de carga de CSV operativo
model OperationsUpload {
  id          String   @id @default(cuid())

  uploadedByUserId String
  uploadedByUser   User   @relation("UploadCreator", fields: [uploadedByUserId], references: [id])

  originalFilename String
  processedAt   DateTime?
  status        String   @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED

  totalRows    Int      @default(0)
  validRows    Int      @default(0)
  invalidRows  Int      @default(0)

  notes        String?  @db.Text

  // Métricas asociadas a esta carga
  metrics      OperationsMetric[]

  createdAt    DateTime @default(now())

  @@index([uploadedByUserId])
  @@index([status])
  @@index([createdAt])
}

// Métrica operativa por agente (snapshot de una carga)
model OperationsMetric {
  id          String   @id @default(cuid())

  uploadId    String
  upload      OperationsUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  // Identificación del agente
  employeeId  String?
  agent       User?    @relation(fields: [employeeId], references: [id])

  // Datos raw del CSV para referencia
  agentNameRaw    String?
  leaderNameRaw   String?
  skillRaw        String?

  // Estado actual
  currentStatus       String?  // READY | NOT_READY | ACW | BREAK | COACHING | etc
  timeInStatusSeconds Int?     // Tiempo en el estado actual

  // Tiempos en segundos
  loginTimeSeconds        Int?   // Tiempo logueado
  continuousLoginTimeSeconds Int? // Tiempo continuo logueado
  tmoSeconds              Int?   // Tiempo Medio de Operación (AHT)
  breakSeconds            Int?   // Tiempo en break
  coachingSeconds         Int?   // Tiempo en coaching
  acwSeconds              Int?   // After Call Work
  holdSeconds             Int?   // Tiempo en espera

  // Contadores
  transfersCount          Int?    // Cantidad de transferencias
  attendedCallsCount      Int?    // Llamadas atendidas (ATN)

  // Tiempos de llamada
  inboundTimeSeconds      Int?    // Tiempo en inbound
  outboundTimeSeconds     Int?    // Tiempo en outbound
  handleTimeSeconds       Int?    // Tiempo total de manejo

  // Datos crudos del CSV
  rawPayloadJson          Json?

  createdAt   DateTime @default(now())

  @@index([uploadId])
  @@index([employeeId])
  @@index([createdAt])
}

// Objetivos individuales cargados por líder para un agente
model AgentGoal {
  id          String   @id @default(cuid())

  // Líder que asigna el objetivo
  leaderId    String
  leader      User     @relation("LeaderAssignedGoals", fields: [leaderId], references: [id], onDelete: Cascade)

  // Agente objetivo
  agentEmployeeId String
  agent        User     @relation("AgentGoalTarget", fields: [agentEmployeeId], references: [id], onDelete: Cascade)

  // Período del objetivo
  periodMonth Int      // 1-12
  periodYear  Int      // 2024, 2025, etc

  // Objetivos operativos
  targetTmoSeconds   Int?    // TMO objetivo en segundos
  targetFcr          Float?  // First Call Resolution (%) 0-100
  targetNps          Float?  // Net Promoter Score (-100 a 100)
  targetRel          Float?  // Resolución en primer nivel (%) 0-100

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([leaderId, agentEmployeeId, periodMonth, periodYear])
  @@index([leaderId])
  @@index([agentEmployeeId])
  @@index([periodMonth, periodYear])
  @@index([isActive])
}
